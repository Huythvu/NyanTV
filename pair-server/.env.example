# ── NyanTV pairing relay — environment variables ────────────────────────────
# Set these in the Vercel project (Settings → Environment Variables).

# AniList API client (https://anilist.co/settings/developer)
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=
# Must EXACTLY match the redirect URL registered on your AniList client, e.g.
#   https://pair.yourdomain.tld/api/pair/callback
ANILIST_REDIRECT_URI=

# Public base URL of THIS deployment (used to build the verify/QR link).
# Optional — falls back to the request host if unset. e.g. https://pair.yourdomain.tld
PUBLIC_BASE_URL=

# ── Storage (Redis/KV via Upstash) ───────────────────────────────────────────
# Connect an Upstash (Redis) store from Vercel's Storage/Marketplace tab. It auto-injects the
# REST credentials. The code accepts either naming, so nothing to set here manually:
#   KV_REST_API_URL / KV_REST_API_TOKEN        (Vercel-integrated names)
#   UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN   (Upstash-native names)
